/*
 * tpbk_@KERNEL_NAME@.c
 * Minimal TPBench PLI kernel template: accumulate 1..n and report count.
 */

#include <inttypes.h>
#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

#include "tpbench.h"

/* Local Function Prototypes */
static int _tpbk_run_@KERNEL_NAME@(void);
int tpbk_pli_register_@KERNEL_NAME@(void);

int
tpbk_pli_register_@KERNEL_NAME@(void)
{
    int err;

    err = tpb_k_register("@KERNEL_NAME@",
                         "Minimal template kernel: sum 1..n iterations.",
                         TPB_KTYPE_PLI);
    if (err != 0) {
        return err;
    }

    err = tpb_k_add_parm("n", "Number of iterations", "10",
                         TPB_PARM_CLI | TPB_INT64_T | TPB_PARM_RANGE,
                         (int64_t)1, (int64_t)1000000);
    if (err != 0) {
        return err;
    }

    err = tpb_k_add_output("FOM,COUNT::Value",
                           "Sum of integers from 1 through n.",
                           TPB_DOUBLE_T,
                           TPB_UNAME_UNDEF | TPB_UBASE_BASE |
                           TPB_UATTR_CAST_N | TPB_UATTR_TRIM_N |
                           TPB_UATTR_SHAPE_POINT);
    if (err != 0) {
        return err;
    }

    return tpb_k_finalize_pli();
}

static int
_tpbk_run_@KERNEL_NAME@(void)
{
    int64_t n;
    double *value;
    int err;
    int64_t i;

    err = tpb_k_get_arg("n", TPB_INT64_T, (void *)&n);
    if (err != 0) {
        return err;
    }
    if (n < 1) {
        tpb_printf(TPBM_PRTN_M_DIRECT,
                   "@KERNEL_NAME@: n must be >= 1, got %" PRId64 "\n", n);
        return TPBE_KERN_ARG_FAIL;
    }

    err = tpb_k_alloc_output("FOM,COUNT::Value", 1, (void **)&value);
    if (err != 0) {
        return err;
    }

    value[0] = 0.0;
    for (i = 1; i <= n; i++) {
        value[0] += (double)i;
    }

    tpb_printf(TPBM_PRTN_M_DIRECT,
               "@KERNEL_NAME@: n=%" PRId64 " sum=%.0f\n", n, value[0]);
    return TPBE_SUCCESS;
}

int
tpbk_@KERNEL_NAME@_entry(int argc, char **argv)
{
    int err;
    tpb_k_rthdl_t handle;
    const char *timer_name;

    err = tpb_k_corelib_init(NULL);
    if (err != 0) {
        fprintf(stderr, "Error: tpb_k_corelib_init failed: %d\n", err);
        return err;
    }

    timer_name = (argc >= 2) ? argv[1] : getenv("TPBENCH_TIMER");
    if (timer_name == NULL) {
        fprintf(stderr,
                "Error: Timer not specified (argv[1] or TPBENCH_TIMER)\n");
        return TPBE_CLI_FAIL;
    }

    err = tpb_k_pli_set_timer(timer_name);
    if (err != 0) {
        fprintf(stderr, "Error: Failed to set timer '%s'\n", timer_name);
        return err;
    }

    err = tpbk_pli_register_@KERNEL_NAME@();
    if (err != 0) {
        fprintf(stderr, "Error: Failed to register kernel\n");
        return err;
    }

    err = tpb_k_pli_build_handle(&handle, argc - 2, argv + 2);
    if (err != 0) {
        fprintf(stderr, "Error: Failed to build handle\n");
        return err;
    }

    tpb_cliout_args(&handle);
    tpb_printf(TPBM_PRTN_M_DIRECT, "Kernel logs\n");
    err = _tpbk_run_@KERNEL_NAME@();
    if (err != 0) {
        tpb_printf(TPBM_PRTN_M_TSTAG | TPBE_FAIL,
                   "Kernel @KERNEL_NAME@ failed: %d\n", err);
        return err;
    }

    tpb_cliout_results(&handle);
    tpb_printf(TPBM_PRTN_M_TSTAG | TPBE_NOTE,
               "Kernel @KERNEL_NAME@ finished successfully.\n");
    tpb_k_write_task(&handle, 0, NULL);
    tpb_driver_clean_handle(&handle);
    return TPBE_SUCCESS;
}

int
main(int argc, char **argv)
{
    return tpbk_@KERNEL_NAME@_entry(argc, argv);
}
